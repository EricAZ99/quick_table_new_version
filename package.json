{
  "name": "quicktable",
  "version": "0.0.0",
  "private": true,
  "description": "QuickTable — plateforme SaaS multi-tenant de gestion de restaurants (docs/architecture/00-INDEX.md).",
  "license": "UNLICENSED",
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "packageManager": "pnpm@11.13.0",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "dev": "pnpm -r --parallel --if-present dev",
    "test": "pnpm -r --if-present test",
    "typecheck": "pnpm -r --if-present typecheck",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "prettier": "@quicktable/config/prettier",
  "lint-staged": {
    "**/*.{ts,tsx,vue,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.{json,md,yml,yaml,html}": "prettier --write --ignore-unknown"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@quicktable/config": "workspace:*",
    "eslint": "^9.15.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "typescript-eslint": "^8.15.0"
  }
}
