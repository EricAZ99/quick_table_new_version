  },
  "devDependencies": {
    "@quicktable/config": "workspace:*",
    "@types/express": "^4.17.21",
    "@types/node": "^22.9.0",
    "eslint": "^9.15.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
