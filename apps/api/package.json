{
  "name": "@quicktable/api",
  "version": "0.0.0",
  "private": true,
  "description": "Backend QuickTable — Express + Socket.IO + Workers (docs/architecture/03-arborescence-projet.md §3.3, ADR 0002).",
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/workers/worker.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "start:worker": "node dist/workers/worker.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "seed:country-defaults": "tsx src/database/seeders/run-country-defaults.ts"
  },
  "dependencies": {
    "argon2": "^0.44.0",
    "bullmq": "^5.80.3",
    "cookie-parser": "^1.4.7",
    "express": "^4.21.1",
    "express-rate-limit": "^8.5.2",
    "ioredis": "5.10.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.7.4",
    "nodemailer": "^9.0.3",
    "otplib": "^13.4.1",
    "pino": "^10.3.1",
    "qrcode": "^1.5.4",
    "rate-limit-redis": "^5.0.0",
    "redis": "^6.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@quicktable/config": "workspace:*",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.9.0",
    "@types/nodemailer": "^8.0.1",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
